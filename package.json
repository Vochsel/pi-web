{
  "name": "pi-web",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "smoke:rpc": "bun run packages/client/scripts/smoke-rpc.ts",
    "clean": "rm -rf .turbo node_modules packages/*/dist apps/*/.next"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "tsup": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
